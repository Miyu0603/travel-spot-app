# Copy this file to .env and fill in your API keys

# Apify (for IG/FB scraping)
APIFY_API_TOKEN=

# OpenAI (for LLM extraction & Whisper transcription)
OPENAI_API_KEY=

# Google Maps / Places API
GOOGLE_MAPS_API_KEY=

# Database (default: SQLite, switch to PostgreSQL for production)
DATABASE_URL=sqlite:///./travel_spots.db
